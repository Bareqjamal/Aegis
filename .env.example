# =============================================================================
# Project Aegis — Environment Variables
# =============================================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -- App Settings -------------------------------------------------------------
APP_PORT=8501

# -- PostgreSQL (future multi-user support) -----------------------------------
POSTGRES_USER=aegis
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=aegis_db
POSTGRES_PORT=5432

# -- Redis Cache --------------------------------------------------------------
REDIS_PORT=6379

# -- Brain Service (background scheduler + API) ------------------------------
BRAIN_PORT=8502
BRAIN_INTERVAL_MIN=30
MORNING_EMAIL_HOUR=7
MORNING_EMAIL_MIN=0

# -- Email (SMTP for verification + morning emails) --------------------------
AEGIS_SMTP_HOST=
AEGIS_SMTP_PORT=587
AEGIS_SMTP_USER=
AEGIS_SMTP_PASS=
AEGIS_SMTP_FROM=noreply@aegis-terminal.com

# -- Optional API Keys (not required for core functionality) ------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
